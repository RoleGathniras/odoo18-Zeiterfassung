<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_attendance_rule_tree" model="ir.ui.view">
        <field name="name">hr.attendance.rule.list</field>
        <field name="model">hr.attendance.rule</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="active"/>
                <field name="break_6h_threshold"/>
                <field name="break_6h_minutes"/>
                <field name="break_6h_grace_minutes"/>
                <field name="break_9h_threshold"/>
                <field name="break_9h_minutes"/>
                <field name="break_9h_grace_minutes"/>
                <field name="max_daily_hours"/>
            </list>
        </field>
    </record>

    <record id="view_attendance_rule_form" model="ir.ui.view">
        <field name="name">hr.attendance.rule.form</field>
        <field name="model">hr.attendance.rule</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="active"/>
                    </group>

                    <group string="Pausenregel">
                        <field name="break_6h_threshold"/>
                        <field name="break_6h_minutes"/>
                        <field name="break_6h_grace_minutes"/>
                        <field name="break_9h_threshold"/>
                        <field name="break_9h_minutes"/>
                        <field name="break_9h_grace_minutes"/>
                    </group>

                    <group string="Arbeitszeit">
                        <field name="max_daily_hours"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_attendance_rule" model="ir.actions.act_window">
        <field name="name">Arbeitszeitregeln</field>
        <field name="res_model">hr.attendance.rule</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem
        id="menu_attendance_rule_root"
        name="Compliance"
        parent="hr_attendance.menu_hr_attendance_root"
        sequence="100"
    />

    <menuitem
        id="menu_attendance_rule"
        name="Arbeitszeitregeln"
        parent="menu_attendance_rule_root"
        action="action_attendance_rule"
        sequence="10"
    />
</odoo>